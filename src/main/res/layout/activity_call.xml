<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/call_root_view"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/call_bg_gradient"
    android:fitsSystemWindows="false">

    <!-- ── Glow blobs (ambient light, breathe-animated in Java) ───── -->

    <View
        android:id="@+id/glow_top_left"
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:background="@drawable/call_glow_blob"
        android:translationX="-70dp"
        android:translationY="-70dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/glow_bottom_right"
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:background="@drawable/call_glow_blob"
        android:translationX="70dp"
        android:translationY="70dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- ── Remote video (full screen, behind all UI) ──────────────── -->

    <org.webrtc.SurfaceViewRenderer
        android:id="@+id/remote_video_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── Center info block: rings + avatar + name + status ─────── -->
    <!--
        Vertical bias 0.35: upper-center of screen, matching iOS call layout.
        Constrained bottom to the top of call_controls_layout so it naturally
        shifts up when call_controls_layout is visible.
    -->

    <LinearLayout
        android:id="@+id/center_info_block"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/call_controls_layout"
        app:layout_constraintVertical_bias="0.35">

        <!-- Rings + avatar, stacked in a 224dp square -->
        <FrameLayout
            android:layout_width="224dp"
            android:layout_height="224dp">

            <org.thoughtcrime.securesms.calls.PulsingRingsView
                android:id="@+id/rings_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center" />

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/remote_avatar_view"
                android:layout_width="125dp"
                android:layout_height="125dp"
                android:layout_gravity="center"
                android:scaleType="centerCrop"
                android:contentDescription="Contact photo"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
                tools:src="@drawable/ic_person" />

        </FrameLayout>

        <!-- Contact name -->
        <TextView
            android:id="@+id/display_name_text"
            android:layout_width="240dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            android:gravity="center"
            android:maxLines="1"
            android:autoSizeTextType="uniform"
            android:autoSizeMinTextSize="18sp"
            android:autoSizeMaxTextSize="28sp"
            tools:text="John Doe" />

        <!-- Status line / call timer -->
        <TextView
            android:id="@+id/status_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="#D9FFFFFF"
            android:textSize="16sp"
            tools:text="Connecting..." />

    </LinearLayout>

    <!-- ── PiP button (top-left) ───────────────────────────────────── -->

    <ImageButton
        android:id="@+id/pip_button"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginStart="12dp"
        android:layout_marginTop="8dp"
        android:src="@drawable/ic_pip"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:tint="#FFFFFF"
        android:contentDescription="Picture in picture"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- ── Local video corner (top-right, when camera is ON) ────────  -->

    <FrameLayout
        android:id="@+id/local_video_container"
        android:layout_width="120dp"
        android:layout_height="150dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="16dp"
        android:visibility="gone"
        android:clipChildren="true"
        android:clipToPadding="true"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <org.webrtc.SurfaceViewRenderer
            android:id="@+id/local_video_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- Switch-camera overlay button in bottom-right of preview -->
        <ImageButton
            android:id="@+id/switch_camera_button"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="bottom|end"
            android:layout_margin="6dp"
            android:background="@drawable/call_button_inactive"
            android:src="@drawable/ic_switch_camera"
            android:tint="#FFFFFF"
            android:contentDescription="Switch camera"
            android:padding="8dp" />

    </FrameLayout>

    <!-- ── 4 call-control buttons (during active call) ─────────────── -->

    <LinearLayout
        android:id="@+id/call_controls_layout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingBottom="40dp"
        android:visibility="gone"
        android:clipChildren="false"
        android:clipToPadding="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Speaker -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <ImageButton
                android:id="@+id/speaker_button"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:src="@drawable/ic_volume_up"
                android:background="@drawable/call_button_inactive"
                android:tint="#FFFFFF"
                android:contentDescription="Speaker"
                android:padding="18dp" />

        </LinearLayout>

        <!-- Camera — off (inactive) by default for audio calls -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <ImageButton
                android:id="@+id/video_button"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:src="@drawable/ic_videocam_off"
                android:background="@drawable/call_button_inactive"
                android:tint="#FFFFFF"
                android:contentDescription="Toggle camera"
                android:padding="18dp" />

        </LinearLayout>

        <!-- Microphone — on (green) by default -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <ImageButton
                android:id="@+id/mute_button"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:src="@drawable/ic_mic_on"
                android:background="@drawable/call_button_active_green"
                android:tint="#FFFFFF"
                android:contentDescription="Toggle microphone"
                android:padding="18dp" />

        </LinearLayout>

        <!-- End call — always red -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <ImageButton
                android:id="@+id/end_call_button"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:src="@drawable/ic_call_end"
                android:background="@drawable/call_button_end"
                android:tint="#FFFFFF"
                android:contentDescription="End call"
                android:padding="18dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- ── Incoming call prompt (Answer / Decline) ────────────────── -->

    <LinearLayout
        android:id="@+id/incoming_call_prompt"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"
        android:paddingBottom="48dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/decline_button"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginEnd="12dp"
            android:text="Decline"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            app:icon="@drawable/ic_call_end"
            app:iconGravity="textStart"
            app:cornerRadius="28dp"
            style="@style/Widget.Material3.Button.TonalButton"
            app:backgroundTint="@color/calls_red" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/answer_button"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="Answer"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            app:icon="@drawable/ic_call"
            app:iconGravity="textStart"
            app:cornerRadius="28dp"
            style="@style/Widget.Material3.Button"
            app:backgroundTint="@color/calls_green" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>

