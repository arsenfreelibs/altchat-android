<?xml version="1.0" encoding="utf-8"?>

<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/conversation_container"
    android:layout_width="fill_parent"
    android:layout_height="match_parent">

    <androidx.recyclerview.widget.RecyclerView
        android:id="@android:id/list"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="8dp"
        android:scrollbars="vertical"
        android:cacheColorHint="?conversation_background"
        android:clipChildren="false"
        android:clipToPadding="false" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/no_messages_text_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="visible"
        style="@style/NoMessagesTextView"
        tools:text="@string/chat_new_one_to_one_hint" />

    <View
        android:id="@+id/bottom_divider"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:layout_gravity="bottom"
        android:background="@drawable/compose_divider_background"
        android:alpha="1" />

    <ImageButton
        android:id="@+id/floating_location_button"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="6dp"
        android:layout_marginRight="6dp"
        android:layout_marginTop="8dp"
        android:layout_gravity="top|end"
        android:padding="5dp"
        android:background="?attr/floating_mini_bg"
        android:elevation="1dp"
        android:alpha="0.9"
        android:contentDescription="Location streaming enabled"
        android:src="@drawable/ic_location_on_white_24dp"
        android:tint="@color/location_icon" />

    <ImageButton
        android:id="@+id/scroll_to_bottom_button"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="10dp"
        android:layout_marginRight="10dp"
        android:layout_marginBottom="20dp"
        android:layout_gravity="bottom|end"
        android:paddingTop="10dp"
        android:paddingBottom="6dp"
        android:paddingLeft="8dp"
        android:paddingRight="8dp"
        android:background="?attr/floating_mini_bg"
        android:tint="@color/gray50"
        android:elevation="1dp"
        android:alpha="0.9"
        android:contentDescription="@string/menu_scroll_to_bottom"
        android:src="@drawable/ic_search_down" />

    <org.thoughtcrime.securesms.reactions.AddReactionView
        android:id="@+id/add_reaction_view"
        android:visibility="invisible"
        android:orientation="horizontal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingStart="7dp"
        android:paddingEnd="7dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:gravity="center"
        android:background="@drawable/reaction_pill_background">

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/reaction_0"
            android:text="👍"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/AddReaction" />
        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/reaction_1"
            android:text="👎"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/AddReaction" />
        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/reaction_2"
            android:text="❤️"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/AddReaction" />
        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/reaction_3"
            android:text="😂"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/AddReaction" />
        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/reaction_4"
            android:text="🙁"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/AddReaction" />
        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/reaction_any"
            android:text="⋯"
            android:textColor="?attr/pref_icon_tint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/AddReaction" />
    </org.thoughtcrime.securesms.reactions.AddReactionView>

    <!-- Telegram-style actions overlay (short tap) -->
    <org.thoughtcrime.securesms.MessageContextOverlay
        android:id="@+id/message_context_overlay"
        android:visibility="gone"
        android:orientation="vertical"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minWidth="220dp"
        android:background="@drawable/popup_menu_background"
        android:elevation="8dp">

        <!-- Action items -->
        <TextView
            android:id="@+id/ctx_action_reply"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:drawablePadding="16dp"
            android:textSize="15sp"
            android:visibility="gone"
            android:background="?attr/selectableItemBackground"
            android:drawableStart="@drawable/ic_selection_reply"
            android:drawableTint="?android:attr/textColorPrimary"
            android:text="@string/notify_reply_button" />

        <TextView
            android:id="@+id/ctx_action_copy"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:drawablePadding="16dp"
            android:textSize="15sp"
            android:background="?attr/selectableItemBackground"
            android:drawableStart="@drawable/ic_content_copy_white_24dp"
            android:drawableTint="?android:attr/textColorPrimary"
            android:text="@string/menu_copy_text_to_clipboard" />

        <TextView
            android:id="@+id/ctx_action_forward"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:drawablePadding="16dp"
            android:textSize="15sp"
            android:background="?attr/selectableItemBackground"
            android:drawableStart="@drawable/ic_selection_forward"
            android:drawableTint="?android:attr/textColorPrimary"
            android:text="@string/forward" />

        <TextView
            android:id="@+id/ctx_action_save"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:drawablePadding="16dp"
            android:textSize="15sp"
            android:visibility="gone"
            android:background="?attr/selectableItemBackground" />

        <TextView
            android:id="@+id/ctx_action_delete"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:drawablePadding="16dp"
            android:textSize="15sp"
            android:textColor="#ffff0c16"
            android:background="?attr/selectableItemBackground"
            android:drawableStart="@drawable/ic_delete_white_24dp"
            android:drawableTint="#ffff0c16"
            android:text="@string/delete" />

    </org.thoughtcrime.securesms.MessageContextOverlay>

</FrameLayout>
